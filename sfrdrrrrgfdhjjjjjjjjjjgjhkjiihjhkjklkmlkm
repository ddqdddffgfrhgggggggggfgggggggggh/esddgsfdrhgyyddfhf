        staffInspUI.statusLabel.Text = "Pas de personnage"
        staffInspUI.statusLabel.TextColor3 = Color3.fromRGB(255, 150, 150)
    end
    for _, child in pairs(staffInspUI.invScroll:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
    local hasItems = false
    local backpack = targetPlayer:FindFirstChild("Backpack")
    if backpack then
        for _, item in pairs(backpack:GetChildren()) do
            if item:IsA("Tool") then
