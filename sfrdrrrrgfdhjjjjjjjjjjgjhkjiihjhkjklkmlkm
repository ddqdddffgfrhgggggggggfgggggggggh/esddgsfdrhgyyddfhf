        if desc:IsA("BasePart") and desc.Name == "Tache" then
            table.insert(result, desc)
        end
    end
    return result
end

local function StopAutoFarmConcierge()
    AF.Active = false
    
    if AF.SpinConnection then
        AF.SpinConnection:Disconnect()
        AF.SpinConnection = nil
    end
    
    -- Destroy GUI
    local farmGui = CoreGui:FindFirstChild("AutoFarmConciergeGui")
    if farmGui then
        farmGui:Destroy()
    end
    
    Library:Notification("Auto Farm", "Auto Farm Arrete", 5)
end

local function StartAutoFarmConcierge()
    if not IsAgentEntretien() then
        Library:Notification("Auto Farm", "Tu n'es pas AgentEntretien", 5)
        return
    end
    
    AF.Active = true
    
    -- GUI groupé dans une table
    local gui = {}
    gui.farmGui = Instance.new("ScreenGui")
    gui.farmGui.Name = "AutoFarmConciergeGui"
    gui.farmGui.ResetOnSpawn = false
    gui.farmGui.DisplayOrder = 2147483647
    gui.farmGui.IgnoreGuiInset = true
    gui.farmGui.Parent = CoreGui
    
    gui.bgFrame = Instance.new("Frame")
    gui.bgFrame.Size = UDim2.new(1, 0, 1, 0)
    gui.bgFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    gui.bgFrame.BackgroundTransparency = 0.5
    gui.bgFrame.BorderSizePixel = 0
    gui.bgFrame.Parent = gui.farmGui
    
    -- Créer labels en table
    local function CreateLabel(text, posY, color)
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(0.5, 0, 0.07, 0)
        lbl.Position = UDim2.new(0.25, 0, posY, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text = text
        lbl.TextColor3 = color or Color3.fromRGB(255, 255, 255)
        lbl.TextScaled = true
        lbl.Font = Enum.Font.GothamBold
        lbl.TextStrokeTransparency = 0
        lbl.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        lbl.Parent = gui.bgFrame
        return lbl
    end
    
    -- Labels dans une table
    local labels = {
        title = CreateLabel("Auto Farm Neptune", 0.05, Color3.fromRGB(255, 255, 255)),
        startMoney = CreateLabel("Depart: 0 $", 0.15, Color3.fromRGB(200, 200, 200)),
        currentMoney = CreateLabel("Actuel: 0 $", 0.25, Color3.fromRGB(255, 255, 100)),
        gain = CreateLabel("Gagne: +0 $", 0.35, Color3.fromRGB(100, 255, 100)),
        timer = CreateLabel("Temps: 00:00:00", 0.45, Color3.fromRGB(150, 200, 255)),
        tache = CreateLabel("Tache: 0 / 0", 0.55, Color3.fromRGB(200, 150, 255))
    }
    
    -- Bouton
    gui.toggleBtn = Instance.new("TextButton")
    gui.toggleBtn.Size = UDim2.new(0.8, 0, 0.15, 0)
    gui.toggleBtn.Position = UDim2.new(0.1, 0, 0.80, 0)
    gui.toggleBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    gui.toggleBtn.BorderSizePixel = 0
    gui.toggleBtn.Text = "Pour stop le autofarm\nfaut re cliquer sur le toggle"
    gui.toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    gui.toggleBtn.TextSize = 10
    gui.toggleBtn.TextScaled = true
    gui.toggleBtn.Font = Enum.Font.GothamBold
    gui.toggleBtn.Parent = gui.bgFrame
    SetCorner(gui.toggleBtn, 14)
    
    local btnStroke = Instance.new("UIStroke")
    btnStroke.Color = Color3.fromRGB(255, 100, 100)
    btnStroke.Thickness = 3
    btnStroke.Parent = gui.toggleBtn
    
    gui.toggleBtn.MouseButton1Click:Connect(function()
        task.wait(0.1)
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp then 
            hrp.CFrame = CFrame.new(FARM_SPAWN_POSITION) 
        end
        Library.Flags["AutoFarmConcierge"] = false
    end)
    
    -- Stats groupées
    local stats = {
        startMoney = LocalPlayer:GetAttribute("Argent") or 0,
        startTick = tick()
    }
    labels.startMoney.Text = "Depart: " .. stats.startMoney .. " $"
    labels.currentMoney.Text = "Actuel: " .. stats.startMoney .. " $"
    
    -- Spin
    AF.SpinConnection = RunService.RenderStepped:Connect(function()
        if not AF.Active then return end
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(15), 0)
        end
    end)
    
    -- Argent update
    LocalPlayer:GetAttributeChangedSignal("Argent"):Connect(function()
        if not AF.Active then return end
        local current = LocalPlayer:GetAttribute("Argent") or 0
        labels.currentMoney.Text = "Actuel: " .. current .. " $"
        labels.gain.Text = "Gagne: +" .. (current - stats.startMoney) .. " $"
    end)
    
    -- Remote
    local remote = ReplicatedStorage:WaitForChild("Charpente_Partage"):WaitForChild("RemoteEvent"):WaitForChild("Tool"):WaitForChild("BalaisRemote")
    
    Library:Notification("Auto Farm", "Auto Farm Active", 5)
    
    -- Fonction pour toutes les taches
    local function DoAllTaches()
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        local taches = GetAllTaches()
        if #taches == 0 then 
            labels.tache.Text = "Aucune tache trouvee"
            return 
        end
        
        local balai = HasBalai()
        if not balai then return end
        
        for i, tache in ipairs(taches) do
            if not AF.Active then break end
            labels.tache.Text = "Tache: " .. i .. " / " .. #taches
            hrp.CFrame = CFrame.new(tache.Position + Vector3.new(0, 3, 0))
            pcall(function() remote:FireServer(balai, hrp.CFrame) end)
            task.wait(0.5)
        end
    end
    
    -- Boucle principale
    AF.Connection = task.spawn(function()
        while AF.Active do
            DoAllTaches()
            if AF.Active then
                labels.tache.Text = "Retour au spawn..."
                local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    hrp.CFrame = CFrame.new(AF.SpawnPos)
                end
                task.wait(0.5)
            end
        end
    end)
    
    -- Timer
    task.spawn(function()
        while AF.Active do
            local elapsed = tick() - stats.startTick
            labels.timer.Text = string.format("Temps: %02d:%02d:%02d",
                math.floor(elapsed / 3600),
                math.floor((elapsed % 3600) / 60),
                math.floor(elapsed % 60)
            )
            task.wait(1)
        end
    end)
end
