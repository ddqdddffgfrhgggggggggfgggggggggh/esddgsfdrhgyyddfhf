    local function parseCash()
        local text = CashLabel.Text
        local numeric = text:gsub("[^%d]", "")
        return tonumber(numeric) or 0
    end
    
    local function formatTime(s)
        return string.format("%02d:%02d:%02d", s/3600, (s/60)%60, s%60)
    end
    
    local startTime = os.time()
    local startCash = parseCash()
    local tasksTotal = #TacheFolder:GetChildren()
    
    DepartLabel.Text = "Depart: " .. startCash .. " $"
    
    task.spawn(function()
        while AF.Active do
            if AF.Active then
                local currentCash = parseCash()
                local diff = currentCash - startCash
                local elapsed = os.time() - startTime
                
                ActuelLabel.Text = "Actuel: " .. currentCash .. " $"
                GagneLabel.Text = "Gagne: +" .. diff .. " $"
                TempsLabel.Text = "Temps: " .. formatTime(elapsed)
                
                local c, t = 0, 0
                for _, v in pairs(TacheFolder:GetChildren()) do
                    t = t + 1
                    if v:GetAttribute("cooldown") then c = c + 1 end
                end
                TacheLabel.Text = "Tache: " .. c .. " / " .. t
            end
            task.wait(0.5)
        end
    end)
    
    task.spawn(function()
        while AF.Active do
            task.wait()
            if AF.Active then
                local items = TacheFolder:GetChildren()
                for i = 1, #items do
                    if not AF.Active then break end
                    local item = items[i]
                    
                    local isBlacklisted = false
                    for _, blacklistedPart in ipairs(AF.Blacklist) do
                        if item == blacklistedPart or item:FindFirstChild("HITREG") == blacklistedPart then
                            isBlacklisted = true
                            break
                        end
                    end
                    
                    if not isBlacklisted and item:IsA("Model") and item:FindFirstChild("HITREG") and item:GetAttribute("cooldown") ~= true then
                        
                        local char = plr.Character
                        local root = char and char:FindFirstChild("HumanoidRootPart")
                        local tool = char and char:FindFirstChild(CONFIG.TOOL_NAME) or plr.Backpack:FindFirstChild(CONFIG.TOOL_NAME)
                        
                        if root and item:FindFirstChild("HITREG") and tool then
                            if tool.Parent ~= char then tool.Parent = char end
                            root.Velocity = Vector3.zero
                            root.CFrame = CFrame.new(item.HITREG.Position + Vector3.new(0, CONFIG.TP_HEIGHT, 0))
                            
                            local s = tick()
                            while AF.Active and item:GetAttribute("cooldown") ~= true and (tick()-s) < CONFIG.MAX_WAIT_PER_PART do
                                BalaisRemote:FireServer(tool)
                                task.wait(CONFIG.REMOTE_DELAY)
                            end
                        end
                    end
                end
            end
        end
    end)
    
