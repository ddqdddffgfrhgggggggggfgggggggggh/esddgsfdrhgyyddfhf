                if maxValue < minValue then
                    maxValue = minValue
                end

                Data.Min = minValue
                Data.Max = maxValue

                local current = Slider.Value
                if current == nil or current < Data.Min then
                    Slider:Set(Data.Min)
                elseif current > Data.Max then
                    Slider:Set(Data.Max)
                end
            end

            function Slider:Set(Value)
                local minValue = tonumber(Data.Min) or 0
                local maxValue = tonumber(Data.Max) or minValue
                if minValue ~= minValue then
                    minValue = 0
                end
                if maxValue ~= maxValue then
                    maxValue = minValue
                end
                if maxValue < minValue then
                    maxValue = minValue
                end

                local clampedValue = tonumber(Value) or Value
                if type(clampedValue) ~= "number" then
                    clampedValue = minValue
                end
                if clampedValue < minValue then
                    clampedValue = minValue
                elseif clampedValue > maxValue then
                    clampedValue = maxValue
                end

                Slider.Value = Library:Round(clampedValue, Data.Decimals)

                Library.Flags[Slider.Flag] = Slider.Value

                local range = maxValue - minValue
                local ratio = range == 0 and 1 or ((Slider.Value - minValue) / range)
                Items["Accent"]:Tween(TweenInfo.new(Library.Tween.Time, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = UDim2New(ratio, 0, 1, 0)})
