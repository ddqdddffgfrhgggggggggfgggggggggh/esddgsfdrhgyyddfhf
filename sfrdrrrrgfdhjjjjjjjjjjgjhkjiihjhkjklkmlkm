local function applyWeaponSettings()
	if not armeSelectionnee then
		Library:Notification("Erreur", "Sélectionne une arme d'abord.", 5)
		return
	end

	local backpack = player:WaitForChild("Backpack")
	local arme = backpack:FindFirstChild(armeSelectionnee) or (player.Character and player.Character:FindFirstChild(armeSelectionnee))

	if arme and arme:FindFirstChild("ACS_Modulo") then
		local settingsModule = arme.ACS_Modulo:FindFirstChild("Variaveis") and arme.ACS_Modulo.Variaveis:FindFirstChild("Settings")
		if settingsModule and settingsModule:IsA("ModuleScript") then
			local success, weaponSettings = pcall(function() return require(settingsModule) end)
			if not success or type(weaponSettings) ~= "table" then
				Library:Notification("Erreur", "Impossible de require Settings pour : " .. arme.Name, 5)
				return
			end

			weaponSettings.Bullets = settings.bullets

			if toggles.noSpread then
				weaponSettings.MinSpread = 0
				weaponSettings.MaxSpread = 0
                weaponSettings.VRecoil = {0, 0} 
           		weaponSettings.HRecoil = {0, 0} 
				weaponSettings.RecoilPunch = 0 
				weaponSettings.VPunchBase = 0 
				weaponSettings.HPunchBase = 0 
				weaponSettings.DPunchBase = 0 
				weaponSettings.MinRecoilPower = 0 
				weaponSettings.MaxRecoilPower = 0 
				weaponSettings.RecoilPowerStepAmount = 0 
                weaponSettings.SwayBase = 0 
                weaponSettings.WalkMultiplier = 0
                weaponSettings.AimInaccuracyStepAmount = 0
				weaponSettings.CanBreak = false
			end

			if toggles.noRecoil then
				weaponSettings.VRecoil = {0, 0}
				weaponSettings.HRecoil = {0, 0}
				weaponSettings.RecoilPunch = 0


			end

			weaponSettings.Distance = toggles.infiniteRange and math.huge or settings.maxDistance
			weaponSettings.BSpeed = toggles.maxBulletSpeed and math.huge or settings.bulletSpeed
			weaponSettings.BDrop = toggles.noBulletDrop and 0 or weaponSettings.BDrop
			weaponSettings.BulletPenetration = toggles.maxPenetration and math.huge or weaponSettings.BulletPenetration

			if toggles.rapidFire then
				weaponSettings.Mode = "Auto"
				if weaponSettings.FireModes then
					weaponSettings.FireModes.Semi = false
					weaponSettings.FireModes.Auto = true
				end
			end

			if toggles.fireRateInf then
				weaponSettings.FireRate = math.huge
				weaponSettings.BurstFireRate = math.huge
				weaponSettings.BurstShot = math.huge
			end

			local dmg = {settings.degats, settings.degats}
			weaponSettings.LimbsDamage = dmg
			weaponSettings.TorsoDamage = dmg
			weaponSettings.HeadDamage = dmg

			weaponSettings.GunSize = settings.gunSize

