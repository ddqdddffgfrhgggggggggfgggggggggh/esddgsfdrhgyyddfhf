local function createTracer(origin, target)
    local m = Instance.new("Model")
    m.Name, m.Parent = "BeamTracer", workspace

    local p0 = Instance.new("Part")
    p0.Anchored, p0.CanCollide, p0.Transparency = true, false, 1
    p0.Size, p0.Position, p0.Parent = Vector3.new(0.1, 0.1, 0.1), origin, m
    
    local a0 = Instance.new("Attachment")
    a0.Parent = p0

    local p1 = Instance.new("Part")
    p1.Anchored, p1.CanCollide, p1.Transparency = true, false, 1
    p1.Size, p1.Position, p1.Parent = Vector3.new(0.1, 0.1, 0.1), target, m
    
    local a1 = Instance.new("Attachment")
    a1.Parent = p1

    local b = Instance.new("Beam")
    b.Attachment0, b.Attachment1 = a0, a1
    b.Color = ColorSequence.new(FX.tracer.color)
    b.Width0, b.Width1, b.Brightness, b.LightEmission, b.FaceCamera = 0.3, 0.3, 100, 1, true
    b.Texture, b.TextureLength, b.TextureSpeed, b.Parent = "rbxassetid://446111271", 5, 3, m

    Debris_ss:AddItem(m, FX.tracer.duration)
end

local function playHitSound()
    local s = Instance.new("Sound")
    s.SoundId, s.Volume, s.Parent = FX.hitSound.soundId, FX.hitSound.volume, workspace
    s:Play()
    Debris_ss:AddItem(s, 3)
end

