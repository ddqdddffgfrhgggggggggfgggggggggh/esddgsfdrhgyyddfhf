local OldNamecall
if hookmetamethod then
    OldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        
        if Config.Enabled and _G.NearestEnemyHead then
            local targetPos = _G.NearestEnemyHead.Position
            
            if method == "FindPartOnRayWithIgnoreList" or method == "FindPartOnRay" or method == "FindPartOnRayWithWhitelist" then
                if args[1] and typeof(args[1]) == "Ray" then
                    local origin = args[1].Origin
                    local direction = (targetPos - origin).Unit * 1000
                    
                    if Config.Wallbang then
                        return _G.NearestEnemyHead, targetPos, targetPos, _G.NearestEnemyHead.Material
                    end
                    
                    args[1] = Ray.new(origin, direction)
                end
            elseif method == "Raycast" then
                if args[1] and typeof(args[1]) == "Vector3" then
                    local origin = args[1]
                    local direction = (targetPos - origin).Unit * 1000
                    
                    if Config.Wallbang then
                        RaycastWhitelist.FilterDescendantsInstances = {_G.NearestEnemyHead}
                        args[3] = RaycastWhitelist
                    end
                    
                    args[2] = direction
                end
            end
        end
        
        return OldNamecall(self, unpack(args))
    end)
else
    warn("hookmetamethod not found - silent aim won't work")
end

