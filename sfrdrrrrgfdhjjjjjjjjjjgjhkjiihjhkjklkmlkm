local ChamsEnabled = _G.Site43.features.chamsEnabled
local ChamsParts = {}
local ChamsColor = Color3.fromRGB(179, 208, 217)
local ChamsLoop = nil

local function applySimpleChams()
    local Character = LocalPlayer.Character
    if not Character then return end
    
    ChamsParts = {}
    for _, part in ipairs(Character:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            table.insert(ChamsParts, part)
        end
    end
    
    for _, part in ipairs(ChamsParts) do
        if part:IsA("BasePart") then
            part.Material = Enum.Material.ForceField
            part.Color = ChamsColor
        end
    end
end

local function removeChams()
    for _, part in ipairs(ChamsParts) do
        if part and part:IsA("BasePart") then
            part.Material = Enum.Material.Plastic
        end
    end
    ChamsParts = {}
end

local function startChamsLoop()
    if ChamsLoop then
        ChamsLoop:Disconnect()
    end
    
    ChamsLoop = task.spawn(function()
        while _G.Site43.features.chamsEnabled do
            applySimpleChams()
            task.wait(5)
        end
    end)
end

local function stopChamsLoop()
    _G.Site43.features.chamsEnabled = false
    if ChamsLoop then
        task.cancel(ChamsLoop)
        ChamsLoop = nil
    end
end

