        if not SkeletonEnabled then return end
        repeat task.wait() until plr.Character and plr.Character:FindFirstChild("Humanoid")

        local limbs = {}
        local R15 = (plr.Character.Humanoid.RigType == Enum.HumanoidRigType.R15)
