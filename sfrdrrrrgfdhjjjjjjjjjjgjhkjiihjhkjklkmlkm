local function updatePlayerInfo(tp)
    if not tp or tp == plr then
        ppUI.main.Visible = false
        return
    end
    
    local userId = tp.UserId
    local thumbType = Enum.ThumbnailType.HeadShot
    local thumbSize = Enum.ThumbnailSize.Size150x150
    ppUI.avatarImg.Image = Players:GetUserThumbnailAsync(userId, thumbType, thumbSize)
    
    ppUI.playerName.Text = tp.Name
    
    local humanoid = tp.Character and tp.Character:FindFirstChild("Humanoid")
    if humanoid then
        ppUI.hpLabel.Text = math.floor(humanoid.Health) .. "/" .. math.floor(humanoid.MaxHealth)
    end
    
    ppUI.teamLabel.Text = tp.Team and tp.Team.Name or "Standard"
    
    ppUI.xpLabel.Text = "XP : " .. (tp:GetAttribute("XP") or "0")
    ppUI.moneyLabel.Text = "ARGENT : " .. (tp:GetAttribute("Argent") or "0")
    
    clearInventory()
    
    if tp:FindFirstChild("Backpack") then
        for _, tool in pairs(tp.Backpack:GetChildren()) do
            if tool:IsA("Tool") then
                local itemFrame = createItemFrame(tool.Name, false)
                itemFrame.Parent = ppUI.invScroll
            end
        end
    end
    
    if tp.Character then
        for _, tool in pairs(tp.Character:GetChildren()) do
            if tool:IsA("Tool") then
                local itemFrame = createItemFrame(tool.Name, true)
                itemFrame.Parent = ppUI.invScroll
            end
        end
    end
    
    ppUI.main.Visible = true
end

