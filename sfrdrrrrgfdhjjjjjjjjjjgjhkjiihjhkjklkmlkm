    local function DrawLine()
        local l = Drawing.new("Line")
        l.Visible = false
        l.From = Vector2.new(0, 0)
        l.To = Vector2.new(1, 1)
        l.Color = SkeletonColor
        l.Thickness = 1
        l.Transparency = 1
        return l
    end

    local function RemoveSkeleton(plr)
        local data = AllSkeletons[plr]
        if not data then return end
        if data.connection then data.connection:Disconnect() end
        for _, line in pairs(data.limbs) do line:Remove() end
        AllSkeletons[plr] = nil
    end

    local function UpdateSkeletonColor(color)
        SkeletonColor = color
        for _, data in pairs(AllSkeletons) do
            if data.limbs then
                for _, line in pairs(data.limbs) do line.Color = color end
            end
        end
    end

