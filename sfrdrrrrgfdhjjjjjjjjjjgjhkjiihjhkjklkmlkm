        end
    end
end

local function updatePlayerInfo(tp)
    if not tp or tp == lp then
        ui.main.Visible = false
        return
    end
    
    local userId = tp.UserId
    local thumbType = Enum.ThumbnailType.HeadShot
    local thumbSize = Enum.ThumbnailSize.Size150x150
    ui.avatarImg.Image = Players:GetUserThumbnailAsync(userId, thumbType, thumbSize)
    
    ui.playerName.Text = tp.Name
    
    local humanoid = tp.Character and tp.Character:FindFirstChild("Humanoid")
    if humanoid then
        ui.hpLabel.Text = math.floor(humanoid.Health) .. "/" .. math.floor(humanoid.MaxHealth)
    end
    
    ui.teamLabel.Text = tp.Team and tp.Team.Name or "Standard"
    
    ui.xpLabel.Text = "XP : " .. (tp:GetAttribute("XP") or "0")
    ui.moneyLabel.Text = "ARGENT : " .. (tp:GetAttribute("Argent") or "0")
    
    clearInventory()
    
    if tp:FindFirstChild("Backpack") then
        for _, tool in pairs(tp.Backpack:GetChildren()) do
            if tool:IsA("Tool") then
                local itemFrame = createItemFrame(tool.Name, false)
                itemFrame.Parent = ui.invScroll
            end
        end
    end
    
    if tp.Character then
        for _, tool in pairs(tp.Character:GetChildren()) do
            if tool:IsA("Tool") then
                local itemFrame = createItemFrame(tool.Name, true)
                itemFrame.Parent = ui.invScroll
            end
        end
    end
    
    ui.main.Visible = true
end


local function getPNames()
    local n = {}
