    local targetPlayer = Players:FindFirstChild(playerName)
    if not targetPlayer then invUI.main.Visible = false return end
    
    invUI.playerName.Text = targetPlayer.Name
    
    pcall(function()
        invUI.avatarImg.Image = Players:GetUserThumbnailAsync(targetPlayer.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size48x48)
    end)
    
    local char = targetPlayer.Character
    if char then
        local hum = char:FindFirstChild("Humanoid")
        if hum then
            invUI.hpLabel.Text = "HP: " .. math.floor(hum.Health) .. "/" .. math.floor(hum.MaxHealth)
        else
            invUI.hpLabel.Text = "HP: ?/?"
        end
    else
        invUI.hpLabel.Text = "HP: En attente..."
    end
    
    clearInv()
    local hasItems = false
    
    local backpack = targetPlayer:FindFirstChild("Backpack")
    if backpack then
        for _, item in pairs(backpack:GetChildren()) do
            if item:IsA("Tool") then
                createInvItemFrame(item.Name, false).Parent = invUI.invScroll
                hasItems = true
            end
        end
    end
    
    if char then
        for _, item in pairs(char:GetChildren()) do
            if item:IsA("Tool") then
                createInvItemFrame(item.Name, true).Parent = invUI.invScroll
                hasItems = true
            end
        end
    end
    
    if not hasItems then
        local emptyItem = createInvItemFrame("Inventaire vide", false)
        emptyItem.Parent = invUI.invScroll
    end
    
    invUI.main.Visible = true
end

