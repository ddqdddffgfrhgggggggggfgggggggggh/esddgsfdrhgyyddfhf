function updateLoader(status, progress)
    progress = math.clamp(progress, 0, 100)
    statusLabel.Text = status
    local targetSize = UDim2.new(progress / 100, 0, 1, 0)
    barFill:TweenSize(
        targetSize,
        Enum.EasingDirection.Out,
        Enum.EasingStyle.Quad,
        CONFIG.BarLerpSpeed,
        true
    )
end

