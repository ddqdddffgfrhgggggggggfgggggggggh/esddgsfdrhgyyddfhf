    "LeftFoot",
    "RightUpperLeg",
    "RightLowerLeg",
    "RightFoot"
}

local particle_auras = {
    ["angel"] = game:GetObjects("rbxassetid://97658130917593")[1],
    ["star"] = game:GetObjects("rbxassetid://73754563740680")[1],
}

local particle_aura = particle_auras["star"]
local local_parts = {}

local function update_local_parts()
    local_parts = {}
    local character = LocalPlayer.Character
    if character then
        for _, part_name in ipairs(body_parts) do
            local part = character:FindFirstChild(part_name)
            if part then
                local_parts[part_name] = part
            end
        end
        local hrp = character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local_parts["HumanoidRootPart"] = hrp
        end
    end
end

local function do_particle_aura()
    for i = 1, #PA.particles do
        if PA.particles[i] then
            PA.particles[i]:Destroy()
        end
        PA.particles[i] = nil
    end

    local hrp = local_parts["HumanoidRootPart"]

    if hrp then
        for aura_name, aura_object in pairs(particle_auras) do
            if aura_object then
                local cloned = aura_object:Clone()
                local children = cloned:GetChildren()

                for i = 1, #children do
                    local part = children[i]
                    local local_part = local_parts[part["Name"]]

                    if local_part then
                        local part_children = part:GetChildren()
                        for j = 1, #part_children do
                            local child = part_children[j]
                            child["Name"] = "\0\0"
                            child["Parent"] = local_part
                            PA.particles[#PA.particles+1] = child
                        end
                    else
                        part:Destroy()
                    end
                end

                cloned:Destroy()
            end
        end
    end
end

local particle_aura_connection = nil

local auraToggle = WorldSection:Toggle({
    Name = "Particle Aura",
    Flag = "particle_aura",
    Default = false,
    Callback = function(v)
        PA.active = v
        wait()

        for i = 1, #PA.particles do
            if PA.particles[i] then
                PA.particles[i]:Destroy()
            end
            PA.particles[i] = nil
        end

        if particle_aura_connection then
            particle_aura_connection:Disconnect()
            particle_aura_connection = nil
        end

        if v then
            update_local_parts()
            spawn(do_particle_aura)
            particle_aura_connection = LocalPlayer.CharacterAdded:Connect(function()
                wait(0.5)
                update_local_parts()
                do_particle_aura()
            end)
        end
    end
})

auraToggle:Colorpicker({
    Name = "Color",
    Flag = "particle_aura_color",
    Color = Color3.fromRGB(179, 208, 217),
    Alpha = 1,
    Callback = function(v)
        local color = ColorSequence.new(v)

        for particle_name, folder in pairs(particle_auras) do
            if folder and typeof(folder) ~= "string" then
                local descendants = folder:GetDescendants()
                for i = 1, #descendants do
                    local part = descendants[i]
                    local class_name = part["ClassName"]
                    if class_name == "PointLight" then
                        part["Color"] = v
                    elseif class_name == "ParticleEmitter" or class_name == "Beam" or class_name == "Trail" then
                        part["Color"] = color
                    end
                end
            end
        end

        local count = #PA.particles
        if count > 0 then
            for i = 1, count do
                local part = PA.particles[i]
                if part then
                    local class_name = part["ClassName"]
                    if class_name == "PointLight" then
                        part["Color"] = v
                    elseif class_name == "ParticleEmitter" or class_name == "Beam" or class_name == "Trail" then
                        part["Color"] = color
                    end

                    local descendants = part:GetDescendants()
                    for j = 1, #descendants do
                        local desc_part = descendants[j]
