                        if desc_class == "PointLight" then
                            desc_part["Color"] = v
                        elseif desc_class == "ParticleEmitter" or desc_class == "Beam" or desc_class == "Trail" then
                            desc_part["Color"] = color
                        end
                    end
                end
            end
        end
    end
