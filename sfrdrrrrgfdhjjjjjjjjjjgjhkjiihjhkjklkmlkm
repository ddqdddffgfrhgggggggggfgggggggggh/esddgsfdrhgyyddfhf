local function ApplyChamsToChar(char, color)
    if AllChams[char] then return end
    local h = Instance.new("Highlight")
    h.Adornee             = char
    h.FillColor           = color
    h.OutlineColor        = color
    h.FillTransparency    = 0.5
    h.OutlineTransparency = 0
    h.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
    h.Parent              = game:GetService("CoreGui")
    AllChams[char]        = h
end

local function RemoveChams(char)
    if AllChams[char] then
        pcall(function() AllChams[char]:Destroy() end)
        AllChams[char] = nil
    end
end

local function RefreshAllChams()
    for char in pairs(AllChams) do RemoveChams(char) end
    if not ESP_Settings.Chams then return end
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= Player and plr.Character then
            ApplyChamsToChar(plr.Character, Settings.Chams_Color)
        end
    end
end

local function UpdateChamsColor(color)
    Settings.Chams_Color = color
    for _, h in pairs(AllChams) do
        pcall(function()
            h.FillColor    = color
            h.OutlineColor = color
        end)
    end
end


local function NewBox(thickness, color)
    local b = Drawing.new("Square")
    b.Visible = false b.Color = color b.Filled = false
    b.Thickness = thickness b.Transparency = 1
    return b
end

local function NewLine2(thickness, color)
    local l = Drawing.new("Line")
    l.Visible = false l.Color = color
    l.Thickness = thickness l.Transparency = 1
    return l
end

local function NewText(size, color)
    local t = Drawing.new("Text")
    t.Visible = false t.Size = size t.Color = color
    t.Center = true t.Outline = true
    return t
end

local function ESP(plr)
    if not plr or plr == Player then return function() end end

    local library = {
        tracer      = NewLine2(Settings.Tracer_Thickness, Settings.Tracer_Color),
        box         = NewBox(Settings.Box_Thickness, Settings.Box_Color),
        healthbar   = NewLine2(3, Color3.fromRGB(0, 0, 0)),
        greenhealth = NewLine2(1.5, Color3.fromRGB(0, 255, 0)),
        nameTag     = NewText(15, Settings.NameTag_Color),
        itemTag     = NewText(15, Settings.Item_Color)
    }

    local connection
    connection = RunService.RenderStepped:Connect(function()
        if ESP_Settings.TeamCheck and plr.Team == Player.Team then
            for _, v in pairs(library) do pcall(function() v.Visible = false end) end
            return
        end

        if plr.Character and plr.Character:FindFirstChild("Humanoid")
            and plr.Character:FindFirstChild("HumanoidRootPart")
            and plr.Character.Humanoid.Health > 0 then

            local HumPos, OnScreen = Camera:WorldToViewportPoint(plr.Character.HumanoidRootPart.Position)

            if OnScreen then
                local head = plr.Character:FindFirstChild("Head")
                if not head then for _, v in pairs(library) do v.Visible = false end return end

                local headPos = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
                local legPos = Camera:WorldToViewportPoint(plr.Character.HumanoidRootPart.Position - Vector3.new(0, 3, 0))
                
                local sizeY = math.abs(headPos.Y - legPos.Y)
                local DistanceY = sizeY / 2

                if ESP_Settings.Box then
                    local bs = Vector2.new(DistanceY * 2, DistanceY * 4)
                    library.box.Size     = bs
                    library.box.Position = Vector2.new(HumPos.X - bs.X/2, HumPos.Y - bs.Y/2)
                    library.box.Color    = Settings.Box_Color
                    library.box.Visible  = true
                else library.box.Visible = false end

                if ESP_Settings.Tracer then
                    local fp = Settings.Tracer_Origin == "Bottom"
                        and Vector2.new(Camera.ViewportSize.X * 0.5, Camera.ViewportSize.Y - 80)
                        or  Vector2.new(Camera.ViewportSize.X * 0.5, Camera.ViewportSize.Y * 0.5)
                    library.tracer.From      = fp
                    library.tracer.To        = Vector2.new(HumPos.X, HumPos.Y + DistanceY * 2)
                    library.tracer.Color     = Settings.Tracer_Color
                    library.tracer.Thickness = Settings.Tracer_Thickness
                    library.tracer.Visible   = true
                else library.tracer.Visible = false end

                if ESP_Settings.HealthBar then
                    local hum = plr.Character:FindFirstChild("Humanoid")
                    local hp  = (hum and hum.MaxHealth > 0) and (hum.Health / hum.MaxHealth) or 0
                    library.healthbar.From      = Vector2.new(HumPos.X - DistanceY - 4, HumPos.Y + DistanceY * 1.3)
                    library.healthbar.To        = Vector2.new(HumPos.X - DistanceY - 4, HumPos.Y - DistanceY * 1.3)
                    library.healthbar.Visible   = true
                    library.greenhealth.From    = Vector2.new(HumPos.X - DistanceY - 4, HumPos.Y + DistanceY * 1.3)
                    library.greenhealth.To      = Vector2.new(HumPos.X - DistanceY - 4, HumPos.Y + DistanceY * 1.3 - DistanceY * 2.6 * hp)
                    library.greenhealth.Color   = Color3.fromRGB(255, 0, 0):Lerp(Color3.fromRGB(0, 255, 0), hp)
                    library.greenhealth.Visible = true
                else
                    library.healthbar.Visible   = false
                    library.greenhealth.Visible = false
                end

                if ESP_Settings.NameTag then
                    library.nameTag.Text     = plr.Name
                    library.nameTag.Position = Vector2.new(headPos.X, headPos.Y - 20)
                    library.nameTag.Color    = Settings.NameTag_Color
                    library.nameTag.Visible  = true
                else library.nameTag.Visible = false end

                if ESP_Settings.Item then
                    local item = nil
                    for _, tool in pairs(plr.Character:GetChildren()) do
                        if tool:IsA("Tool") then item = tool.Name break end
                    end
                    if item then
                        library.itemTag.Text     = item
                        library.itemTag.Position = Vector2.new(HumPos.X, HumPos.Y + DistanceY * 1.3)
                        library.itemTag.Color    = Settings.Item_Color
                        library.itemTag.Visible  = true
                    else library.itemTag.Visible = false end
                else library.itemTag.Visible = false end

            else
                for _, v in pairs(library) do pcall(function() v.Visible = false end) end
            end
        else
            for _, v in pairs(library) do pcall(function() v.Visible = false end) end
        end
    end)

    return function()
        if connection and connection.Connected then connection:Disconnect() end
        for _, v in pairs(library) do pcall(function() v.Visible = false v:Remove() end) end
    end
end



local function HookPlayer(plr)
    if plr == Player then return end

    plr.CharacterAdded:Connect(function(char)
        RemoveChams(char)
        task.wait(0.5) 

        if ESP_Settings.Chams then
            ApplyChamsToChar(char, Settings.Chams_Color)
        end
        if SkeletonEnabled then
            RemoveSkeleton(plr)
            DrawSkeleton(plr)
        end
    end)
end



local activeESPs = {}

local function addPlayer(plr)
    if plr == Player then return end
    if activeESPs[plr] then return end
    activeESPs[plr] = ESP(plr)
    HookPlayer(plr)
    if ESP_Settings.Chams and plr.Character then
        ApplyChamsToChar(plr.Character, Settings.Chams_Color)
    end
end

local function removePlayer(plr)
    if activeESPs[plr] then
        pcall(activeESPs[plr])
        activeESPs[plr] = nil
    end
    if plr.Character then RemoveChams(plr.Character) end
    RemoveSkeleton(plr)
end

for _, plr in pairs(Players:GetPlayers()) do
    addPlayer(plr)
end

Players.PlayerAdded:Connect(addPlayer)
Players.PlayerRemoving:Connect(removePlayer)




