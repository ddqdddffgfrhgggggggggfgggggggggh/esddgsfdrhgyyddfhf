local SelectedGun = nil
local GunCustomizerEnabled = _G.Site43.features.gunCustomizerEnabled
local SelectedMaterial = "Neon"
local SelectedColor = Color3.fromRGB(179, 208, 217)

local function getGunNames()
    local names = {}
    local gunsFolder = ReplicatedStorage:FindFirstChild("ACS_Engine")
    
    if gunsFolder then
        local gunModels = gunsFolder:FindFirstChild("GunModels")
        if gunModels then
            local clientFolder = gunModels:FindFirstChild("Client")
            if clientFolder then
                for _, gun in ipairs(clientFolder:GetChildren()) do
                    table.insert(names, gun.Name)
                end
            end
        end
    end
    
    return names
end

local function applyGunCustomization()
    if not SelectedGun or not _G.Site43.features.gunCustomizerEnabled then return end
    
    local gunPath = ReplicatedStorage:FindFirstChild("ACS_Engine")
    if not gunPath then return end
    
    gunPath = gunPath:FindFirstChild("GunModels")
    if not gunPath then return end
    
    gunPath = gunPath:FindFirstChild("Client")
    if not gunPath then return end
    
    local gunModel = gunPath:FindFirstChild(SelectedGun)
    if not gunModel then return end
    
    for _, part in ipairs(gunModel:GetDescendants()) do
        if part:IsA("BasePart") or part:IsA("MeshPart") then
            part.Material = Enum.Material[SelectedMaterial]
            part.Color = SelectedColor
        end
    end
end

local function resetGunCustomization()
    if not SelectedGun then return end
    
    local gunPath = ReplicatedStorage:FindFirstChild("ACS_Engine")
    if not gunPath then return end
    
    gunPath = gunPath:FindFirstChild("GunModels")
    if not gunPath then return end
    
    gunPath = gunPath:FindFirstChild("Client")
    if not gunPath then return end
    
    local gunModel = gunPath:FindFirstChild(SelectedGun)
    if not gunModel then return end
    
    for _, part in ipairs(gunModel:GetDescendants()) do
        if part:IsA("BasePart") or part:IsA("MeshPart") then
            part.Material = Enum.Material.SmoothPlastic
        end
    end
end

